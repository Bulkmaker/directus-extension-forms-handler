{
  "name": "directus-extension-forms-handler",
  "version": "1.0.0",
  "description": "Form submissions endpoint with modular antispam protection",
  "type": "module",
  "directus:extension": {
    "type": "endpoint",
    "path": "dist/index.js",
    "source": "src/index.ts",
    "host": "^10.0.0 || ^11.0.0"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "vitest": "^4.0.0",
    "@directus/extensions-sdk": "^17.1.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "ioredis": "^5.10.1",
    "nodemailer": "^8.0.7",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@unhead/vue": "^3.1.0",
    "unhead": "^3.1.0"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bulkmaker/directus-extension-forms-handler.git"
  }
}
